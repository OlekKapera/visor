{
  "name": "visor-ai",
  "version": "0.2.4",
  "description": "Visor CLI for LLM-driven mobile app interaction and artifact capture",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AleksKapera/visor"
  },
  "homepage": "https://github.com/AleksKapera/visor",
  "bugs": {
    "url": "https://github.com/AleksKapera/visor/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "visor": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "keywords": [
    "appium",
    "mobile",
    "automation",
    "webdriverio",
    "ios",
    "android",
    "cli"
  ],
  "dependencies": {
    "appium": "^2.17.0",
    "webdriverio": "^9.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
